# Payload CMS endpoint + API auth
PAYLOAD_URL=http://localhost:3002
# Email + password của 1 user trong Payload (role admin) — bot dùng để login
PAYLOAD_BOT_EMAIL=bot@xhr.local
PAYLOAD_BOT_PASSWORD=change-me

# Claude — claude-agent-sdk dùng OAuth Claude Max subscription (KHÔNG cần API key).
# Đảm bảo bạn đã `claude login` trên máy này 1 lần.
CLAUDE_MODEL=claude-sonnet-4-5-20250929
# Đường dẫn binary `claude` (auto-dò nếu để trống). Linux glibc thường cần:
# CLAUDE_BIN=/usr/bin/claude
CLAUDE_BIN=

# MarkItDown service — convert PDF/DOCX/XLSX → markdown text cho AI đọc
# Spin lên: docker run -p 8080:8080 ghcr.io/microsoft/markitdown
# Có thể dùng chung container đã chạy cho skillbot
MARKITDOWN_URL=http://localhost:8080

# Bot HTTP server (cho Payload hooks gọi extract/verify)
BOT_HTTP_PORT=4002
# Shared secret giữa Payload hooks ↔ bot. Đặt cùng giá trị 2 bên.
INTERNAL_SECRET=change-me-internal-secret

# Telegram — TẠO BOT MỚI riêng cho xHR qua @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Logging
LOG_LEVEL=info

# Queue
QUEUE_CONCURRENCY=3
QUEUE_MAX_SIZE=100
QUEUE_JOB_TIMEOUT_MS=120000

# Pipeline
MAX_TOOL_LOOPS=10

# Cron tick interval (ms)
CRON_TICK_MS=10000
